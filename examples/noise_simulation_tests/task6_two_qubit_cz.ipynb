  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "setup",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "\n",
    "%matplotlib notebook\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "from musiq.workflow import create_model\n",
    "from musiq.pulse.sequence import PulseCompiler\n",
    "\n",
    "\n",
    "TASK_DIR = Path(\"task6\")\n",
    "if not (TASK_DIR / \"task.yaml\").exists():\n",
    "    TASK_DIR = Path(\"examples/noise_simulation_tests/task6\")\n",
    "\n",
    "basis = [\"00\", \"01\", \"10\", \"11\"]\n",
    "comp_idx = [0, 1, 3, 4]  # two transmons with nlevel=3: |00>, |01>, |10>, |11>\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "bell-md",
   "metadata": {},
   "source": [
    "## Phi Bell 闁汇埄鍨伴崯顐︽儑閸愬樊鐓堕柡鍐ㄥ€舵禒娌憂",
    "\n",
    "闁哄鏅滈悷銈夋煂?task 闂?`CZ` 闂佸憡鑹炬鍛婃叏閻愬顩?`Ry(-pi/2) q1`闂佹寧绋戦張顒佷繆閹间焦鍎庨梻鈧幇顔拘㈡繛锝呮礌閸撴繃瀵奸崨顔藉妞ゆ帊绀侀悘鍥煕濞嗘ê鐏ｆ繛鎻掓健楠炴帡濡烽…鎴濇闂佸憡鍨煎▍锝呪枔?population闂侀潧妫楅崐鑽ゅ垝閹捐绠戝ù锝呮憸鐎瑰鎮归崶銉ュ姍閻庨潧鐬奸幉鐗堟媴閼恒儱鍔欓梺?`|00>` 闂?`|11>`闂佹寧绋戦惌渚€鍩€椤掆偓婵傛梻绮径鎰強?`|01>`/`|10>`闂?
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "bell-run",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "out_dir: D:\\闁烩剝甯掗幊搴敋闁秵鐓傞煫鍥ㄦ尵閹藉秹鎮规笟濠勭？闁伙絽顭峰鐢稿传閸曨剛褰ｆ繝銏犳贡婢ф鎱ㄩ崒鐐茬缂佸倻娴俼sim\\examples\\noise_simulation_tests\\runs\\task6_two_qubit_cz_bell\n",
      "final P00/P01/P10/P11: {'00': np.float64(0.499472), '01': np.float64(0.028449), '10': np.float64(0.017964), '11': np.float64(0.454096)}\n",
      "phase-optimized Phi Bell fidelity: 0.9140696620852444\n"
     ]
    }
   ],
   "source": [
    "model_bell = create_model(task_config=TASK_DIR / \"task.yaml\")\n",
    "model_bell.run_all()\n",
    "\n",
    "traj_bell = model_bell.results.trajectories[\"solver_0\"]\n",
    "t_bell_ns = np.asarray(traj_bell.times) * 1e9\n",
    "rho_bell_t = np.asarray(traj_bell.density_matrix[\"snapshots\"], dtype=complex)\n",
    "p_bell = np.real(rho_bell_t[:, comp_idx, comp_idx])\n",
    "leakage_bell = 1.0 - np.sum(p_bell, axis=1)\n",
    "\n",
    "rho_bell_final = rho_bell_t[-1][np.ix_(comp_idx, comp_idx)]\n",
    "fid_phi = float(0.5 * (np.real(rho_bell_final[0, 0]) + np.real(rho_bell_final[3, 3]) + 2.0 * abs(rho_bell_final[0, 3])))\n",
    "\n",
    "print(\"out_dir:\", model_bell.out_dir)\n",
    "print(\"final P00/P01/P10/P11:\", dict(zip(basis, np.round(p_bell[-1], 6))))\n",
    "print(\"phase-optimized Phi Bell fidelity:\", fid_phi)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "bell-plot",
