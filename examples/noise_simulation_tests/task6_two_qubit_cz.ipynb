   ],
   "source": [
    "pulse_ir = model_bell.results.solver_runs[\"solver_0\"].pulse_ir\n",
    "pulse_samples = PulseCompiler.compile(pulse_ir, sample_rate_Hz=1e10)\n",
    "\n",
    "fig = plt.Figure(figsize=(8, 5))\n",
    "gs = fig.add_gridspec(2, 2)\n",
    "\n",
    "ax = fig.add_subplot(gs[0, 0])   # 閻庡綊娼荤紓姘辩箔娣囨悏",
    "\n",
    "for channel, waveform in pulse_samples.items():\n",
    "    ax.plot(np.asarray(waveform[\"t\"]) * 1e9, waveform[\"y\"], label=channel)\n",
    "    color = ax.get_lines()[-1].get_color()\n",
    "    if \"y_quadrature\" in waveform:\n",
    "        ax.plot(np.asarray(waveform[\"t\"]) * 1e9, waveform[\"y_quadrature\"], '--', color=color)\n",
    "\n",
    "ax.set_xlabel(\"time (ns)\")\n",
    "ax.set_ylabel(\"pulse amplitude\")\n",
    "# ax.set_title(\"pulse samples\")\n",
    "ax.legend()\n",
    "\n",
    "ax = fig.add_subplot(gs[:, 1])  # 闂佸憡鐟ラ崢鏍疾閸洖鏋侀柡澶嬪灥閻忔瑩鏌ㄥ☉妯肩劮婵炲娲滈幖?2 闂?4\n",
    "for i, label in enumerate(basis):\n",
    "    ax.plot(t_bell_ns, p_bell[:, i], label=f\"P{label}\")\n",
    "ax.plot(t_bell_ns, leakage_bell * 50, label=\"leakage x50\", linestyle='--')\n",
    "ax.set_xlabel(\"time (ns)\")\n",
    "ax.set_ylabel(\"population\")\n",
    "ax.set_ylim(-0.02, 1.02)\n",
    "ax.legend()\n",
    "\n",
    "colors = [line.get_color() for line in ax.get_lines()]\n",
    "ax = fig.add_subplot(gs[1, 0])   # 閻庡綊娼荤紓姘辩箔閸栫晨",
    "p_final = p_bell[-1]\n",
    "ax.bar(basis, p_final, color=colors)\n",
    "ax.set_xlabel(\"basis state\")\n",
    "ax.set_ylabel(\"final population\")\n",
    "ax.set_ylim(0, 1)\n",
    "\n",
    "fig.tight_layout()\n",
    "fig.suptitle(\"CZ Gate and Bell State Preparation\")\n",
    "\n",
    "fig"
   ]
